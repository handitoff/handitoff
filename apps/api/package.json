{
  "name": "@handitoff/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@handitoff/config": "0.0.0",
    "@handitoff/protocol": "0.0.0",
    "@handitoff/turn": "0.0.0",
    "@handitoff/abuse": "0.0.0",
    "@handitoff/analytics": "0.0.0"
  },
  "scripts": {
    "prebuild": "npm run build -w @handitoff/protocol && npm run build -w @handitoff/config && npm run build -w @handitoff/turn && npm run build -w @handitoff/abuse && npm run build -w @handitoff/analytics",
    "build": "tsc -b",
    "dev": "concurrently \"tsc -b --watch --preserveWatchOutput\" \"node --watch dist/server.js\" --names \"tsc,api\" --prefix-colors \"bgGreen.bold,bgCyan.bold\"",
    "start": "node dist/server.js",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests"
  }
}
