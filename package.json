{
  "name": "handitoff-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,md,css,yml}\"",
    "dev:web": "npm run dev -w @handitoff/web",
    "dev:api": "npm run dev -w @handitoff/api",
    "start:api": "npm run build -w @handitoff/api && npm run start -w @handitoff/api"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.2",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
