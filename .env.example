# ── URLs ──────────────────────────────────────────────────────────────────────
HANDITOFF_APP_URL=http://localhost:5173
HANDITOFF_API_URL=http://localhost:8787
HANDITOFF_WS_URL=ws://localhost:8787/ws

# Optional: serve the web SPA from the API process (set to absolute path or
# leave blank to disable static serving and run the web dev server separately).
HANDITOFF_WEB_DIR=

# Optional: set a LAN host IP so phone testing works without separate URL vars.
HANDITOFF_LAN_HOST=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave blank to use in-memory session store (dev only, data lost on restart).
HANDITOFF_REDIS_URL=

# ── ICE / STUN ────────────────────────────────────────────────────────────────
# Override the default STUN server list (JSON array). Leave blank for default.
HANDITOFF_ICE_SERVERS=

# ── TURN (optional, required for reliable cross-network transfers) ─────────────
# Use a managed TURN service (Metered.ca, Twilio, etc.) and paste values here.
HANDITOFF_TURN_ENABLED=false
HANDITOFF_TURN_SECRET=
HANDITOFF_TURN_URLS=
HANDITOFF_TURN_CREDENTIAL_TTL_SECONDS=600

# ── Session limits ─────────────────────────────────────────────────────────────
HANDITOFF_UNPAIRED_SESSION_TTL_SECONDS=600
HANDITOFF_PAIRED_SESSION_TTL_SECONDS=1800
HANDITOFF_MAX_FILES_PER_TRANSFER=100
HANDITOFF_MAX_RECOMMENDED_FILE_SIZE_BYTES=2147483648

# ── Rate limits ───────────────────────────────────────────────────────────────
HANDITOFF_MAX_ACTIVE_SESSIONS_PER_IP=5
HANDITOFF_MAX_JOIN_ATTEMPTS_PER_PUBLIC_CODE=10
HANDITOFF_MAX_SIGNALING_MESSAGES_PER_MINUTE_PER_SESSION=300

# ── Features ──────────────────────────────────────────────────────────────────
HANDITOFF_BILLING_ENABLED=false
HANDITOFF_MULTI_DEVICE_ROOMS=false
HANDITOFF_ACCOUNTS=false

# ── Production / hosted ───────────────────────────────────────────────────────
# Enable stricter IP-based abuse controls (recommended for public deployments).
HANDITOFF_ABUSE_ENABLED=false
# Log anonymous operational analytics to stdout (no PII, no file data).
HANDITOFF_ANALYTICS_ENABLED=false
